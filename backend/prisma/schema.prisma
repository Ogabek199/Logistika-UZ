generator client {
  provider = "prisma-client-js"
}

// Local: SQLite. Production: postgresql + DATABASE_URL
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expenses     Expense[]
}

model Driver {
  id            String   @id @default(cuid())
  fullName      String
  phone         String   @unique
  vehicle       String?
  plateNumber   String?
  passwordHash  String
  passportSeries String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  putyovkas   Putyovka[]
  tirs        Tir[]
  dazvols     Dazvol[]
  licenses    License[]
  rentals     Rental[]
  expenses    Expense[]
}

model Putyovka {
  id        String    @id @default(cuid())
  driverId  String
  driver    Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  trailerNo String?
  code      String?
  price     Float     @default(0)
  paid      Float     @default(0)
  months    Int?
  startDate DateTime?
  endDate   DateTime?
  note      String?
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([driverId])
  @@index([endDate])
}

model Tir {
  id        String    @id @default(cuid())
  driverId  String
  driver    Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  tirNumber String?
  price     Float     @default(0)
  paid      Float     @default(0)
  months    Int?
  startDate DateTime?
  endDate   DateTime?
  note      String?
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([driverId])
  @@index([endDate])
}

model Dazvol {
  id          String    @id @default(cuid())
  driverId    String
  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  country     String?
  dazvolNumber String?
  price       Float     @default(0)
  paid        Float     @default(0)
  startDate   DateTime?
  endDate     DateTime?
  note        String?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([driverId])
  @@index([endDate])
}

model License {
  id            String    @id @default(cuid())
  driverId      String
  driver        Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  licenseNumber String?
  price         Float     @default(0)
  paid          Float     @default(0)
  startDate     DateTime?
  endDate       DateTime?
  note          String?
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([driverId])
  @@index([endDate])
}

model Rental {
  id        String    @id @default(cuid())
  driverId  String
  driver    Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  address   String?
  price     Float     @default(0)
  paid      Float     @default(0)
  startDate DateTime?
  endDate   DateTime?
  note      String?
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([driverId])
  @@index([endDate])
}

model Expense {
  id        String   @id @default(cuid())
  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  type      String
  amount    Float
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([driverId])
  @@index([date])
}
